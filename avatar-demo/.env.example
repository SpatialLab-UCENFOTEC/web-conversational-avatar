# Copia este archivo a `.env` (gitignored) y rellena los valores.
# Las VITE_* se exponen al navegador (build-time). Las demás son solo de servidor.

# --- Secretos de servidor (NUNCA con prefijo VITE_) ---
# API key de Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# (opcional) modelo Gemini; por defecto gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash
# JSON del service account de Google (STT/TTS), en UNA sola línea:
GOOGLE_CREDENTIALS_JSON=

# --- Config del cliente (VITE_*) ---
# Base de las funciones. Local: el proxy express. Prod (Vercel): /api
VITE_CHAT_PROXY_URL=http://localhost:3001
VITE_GOOGLE_TTS_PROXY_URL=http://localhost:3001
VITE_GOOGLE_STT_PROXY_URL=http://localhost:3001
VITE_GCP_PROJECT_ID=alien-program-489205-m5
# Password del gate del demo
VITE_DEMO_PASSWORD=
